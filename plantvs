   Name = "vvu - 😋✌",
   LoadingTitle = "Loading ",
   Theme = "Default"
})

-- Membuat Tab Baru
local FuseTab = Window:CreateTab("Auto Fuse", 4483362458)
local FarmTab = Window:CreateTab("Farming & Dupe", 4483362458)

-- State global
local AUTO_FUSE_TOGGLE = false
local AUTO_BUY_TOGGLE = false
local AUTO_SELL_TOGGLE = false
local AUTO_DUPE_TOGGLE = false
local TARGET_PLOT = "1" 

-- ==========================================
-- SYSTEM INITIALIZATION (AUTO FUSE ENGINE)
-- ==========================================
task.spawn(function()
    local Workspace = game:GetService("Workspace")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    
    local netFolder = ReplicatedStorage:WaitForChild("_Net", 5)
    local movePackEvent = netFolder and netFolder:WaitForChild("MovePack", 5)

    local function findPackVisualAndName(slot)
        if not slot then return nil, nil end
        for _, child in ipairs(slot:GetChildren()) do
            local packVisual = child:FindFirstChild("PackVisual")
            if packVisual then
                local item = packVisual:FindFirstChildWhichIsA("Model") 
                    or packVisual:FindFirstChildWhichIsA("MeshPart") 
                    or packVisual:FindFirstChildWhichIsA("BasePart")
                if item then
                    return packVisual, item.Name
                end
            end
        end
        return nil, nil
    end

    while true do
        if AUTO_FUSE_TOGGLE and movePackEvent then
            local map = Workspace:FindFirstChild("Map")
            local plots = map and map:FindFirstChild("Plots")
            local myPlot = plots and plots:FindFirstChild(TARGET_PLOT)
            local functionals = myPlot and myPlot:FindFirstChild("Functionals")
            local interactibles = functionals and functionals:FindFirstChild("Interactibles")
            local mergeSlots = interactibles and interactibles:FindFirstChild("MergeSlots")

            if mergeSlots then
                local itemScanList = {}
                for _, slot in ipairs(mergeSlots:GetChildren()) do
                    local slotNumber = tonumber(slot.Name)
                    if slotNumber then
                        local packVisual, itemName = findPackVisualAndName(slot)
                        if itemName and itemName ~= "RedIce" then
                            if not itemScanList[itemName] then
                                itemScanList[itemName] = {}
                            end
                            table.insert(itemScanList[itemName], slotNumber)
                        end
                    end
                end

                local fusedThisCycle = false
                for itemName, slotsFound in pairs(itemScanList) do
                    if #slotsFound >= 2 then
                        local args = {slotsFound[1], slotsFound[2]}
                        movePackEvent:FireServer(unpack(args))
                        fusedThisCycle = true
                        task.wait(0.35)
                        break 
                    end
                end
                if not fusedThisCycle then task.wait(0.25) end
            else
                task.wait(0.5)
            end
        else
            task.wait(0.4)
        end
    end
end)

